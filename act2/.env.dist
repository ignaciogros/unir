PROVIDER=azure          # azure | ollama | openai_compat

# Azure
AZURE_ENDPOINT=
AZURE_API_KEY=
AZURE_DEPLOYMENT=
AZURE_API_VERSION=2024-02-01

# Ollama (local)
OLLAMA_MODEL=llama3.1:8b

# OpenAI-compatible (qwen25coder, Mistral-Small, …)
COMPAT_ENDPOINT=
COMPAT_API_KEY=
COMPAT_MODEL=

# Chatbot behaviour
SYSTEM_PROMPT=Eres un asistente útil y conciso.
TEMPERATURE=0.7
MAX_TOKENS=512
TOP_P=1.0
